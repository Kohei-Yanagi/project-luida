        in SetRotation: ${e}. Ensure MovableItem is present and x,y,z are valid numbers
        (Euler degrees).`);\n    }\n}\n\nfunction AddRotation(x, y, z) {\n    try
        {\n        $.setRotation($.getRotation().multiply(new Quaternion().setFromEulerAngles(new
