--- !u!1001 &231365092
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    m_TransformParent: {fileID: 0}
    m_Modifications:
    - target: {fileID: 161685276529953077, guid: de40e14777f5f4d3190981c4f4b1cddf,
        type: 3}
      propertyPath: worldItemReferences.Array.size
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 161685276529953077, guid: de40e14777f5f4d3190981c4f4b1cddf,
        type: 3}
      propertyPath: worldItemReferences.Array.data[0].id
      value: luida-data-collector
      objectReference: {fileID: 0}
    - target: {fileID: 161685276529953077, guid: de40e14777f5f4d3190981c4f4b1cddf,
        type: 3}
      propertyPath: worldItemReferences.Array.data[0].item
      value: 
