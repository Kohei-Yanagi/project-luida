  m_Script: {fileID: 11500000, guid: acb8c4c8a0a4dc6418e2f4d59454f5e3, type: 3}
  m_Name: Portal
  m_EditorClassIdentifier: 
  stateListeners:
  - stateID: 3
    onStateStartedActions:
    - predefinedActionTemplate:
        actionType: Show item
        displayLabel: 
        codeSnippet: $.setStateCompat('this', 'exp_showItem', true);
        variables: []
        category: Item
      customAction: 
      isConditional: 0
      conditionVariable: 
      conditionValue: 
      _variableKeys: []
      _variableValuesList: []
    - predefinedActionTemplate:
        actionType: Set text
        displayLabel: 
        codeSnippet: $.subNode('Text').setText(`{_text_}`);
        variables:
        - text
        category: Item
      customAction: 
      isConditional: 0
      conditionVariable: 
      conditionValue: 
      _variableKeys:
      - text
      _variableValuesList:
      - 'Thank you!

        You can now leave by

        stepping on the portal

        in
        front of you'
    - predefinedActionTemplate:
        actionType: Upload collected data
        displayLabel: Upload saved data from collector
        codeSnippet: $.sendSignalCompat('this', 'exp_uploadCustomData');
        variables: []
        category: Data collection
      customAction: 
      isConditional: 0
      conditionVariable: 
      conditionValue: 
      _variableKeys: []
      _variableValuesList: []
    duringStateActions: []
    onStateExitedActions:
    - predefinedActionTemplate:
        actionType: Hide item
        displayLabel: 
        codeSnippet: $.setStateCompat('this', 'exp_showItem', false);
        variables: []
        category: Item
      customAction: 
      isConditional: 0
