%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: acb8c4c8a0a4dc6418e2f4d59454f5e3, type: 3}
  m_Name: AvatarController
  m_EditorClassIdentifier: 
  stateListeners:
  - stateID: 1
    onStateStartedActions:
    - predefinedActionTemplate:
        actionType: Set participant position
        displayLabel: 
        codeSnippet: PARTICIPANTS[{_participantIndex_}].setPosition(new Vector3({_x_},
          {_y_}, {_z_}));
        variables:
        - participantIndex
        - x
        - y
        - z
        category: Participant transform
      customAction: 
      isConditional: 0
      conditionVariable: 
      conditionValue: 
      _variableKeys:
      - participantIndex
      - x
      - y
      - z
      _variableValuesList:
      - 1
      - 0
      - 0
      - -2
    - predefinedActionTemplate:
        actionType: Unassign avatar from participant
        displayLabel: 
        codeSnippet: '$.worldItemReference(''LUIDA-AvatarSpawner'').send(''luida_unassign_avatar'',
          { participantIndex: {_participantIndex_} });'
        variables:
        - participantIndex
        category: Avatar
      customAction: 
      isConditional: 0
      conditionVariable: 
      conditionValue: 
      _variableKeys:
      - participantIndex
      _variableValuesList:
      - 1
    - predefinedActionTemplate:
        actionType: Sleep
        displayLabel: 
        codeSnippet: '{_seconds_}'
        variables:
        - seconds
        category: State machine
      customAction: 
      isConditional: 0
      conditionVariable: 
      conditionValue: 
      _variableKeys:
      - seconds
      _variableValuesList:
      - 3
    - predefinedActionTemplate:
        actionType: Assign avatar to participant
        displayLabel: 
        codeSnippet: '$.worldItemReference(''LUIDA-AvatarSpawner'').send(''luida_assign_avatar'',
          { avatarID: ''{_avatarID_}'', participantIndex: {_participantIndex_} });'
        variables:
        - avatarID
        - participantIndex
        category: Avatar
      customAction: 
      isConditional: 1
      conditionVariable: avatar
      conditionValue: elder
      _variableKeys:
      - avatarID
      - participantIndex
      _variableValuesList:
      - ElderAvatar
      - 1
    - predefinedActionTemplate:
        actionType: Assign avatar to participant
        displayLabel: 
        codeSnippet: '$.worldItemReference(''LUIDA-AvatarSpawner'').send(''luida_assign_avatar'',
          { avatarID: ''{_avatarID_}'', participantIndex: {_participantIndex_} });'
        variables:
        - avatarID
        - participantIndex
        category: Avatar
      customAction: 
      isConditional: 1
      conditionVariable: avatar
      conditionValue: young
      _variableKeys:
      - avatarID
      - participantIndex
      _variableValuesList:
      - YoungAvatar
      - 1
    duringStateActions: []
    onStateExitedActions: []
  - stateID: 2
    onStateStartedActions: []
    duringStateActions: []
    onStateExitedActions:
    - predefinedActionTemplate:
        actionType: Unassign avatar from participant
        displayLabel: 
        codeSnippet: '$.worldItemReference(''LUIDA-AvatarSpawner'').send(''luida_unassign_avatar'',
          { participantIndex: {_participantIndex_} });'
        variables:
        - participantIndex
        category: Avatar
      customAction: 
      isConditional: 0
      conditionVariable: 
      conditionValue: 
      _variableKeys:
      - participantIndex
      _variableValuesList:
      - 1
  eventHandlers: []
  otherImplementation: 
