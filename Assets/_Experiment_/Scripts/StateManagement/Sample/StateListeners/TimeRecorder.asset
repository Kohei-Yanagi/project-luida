  m_Script: {fileID: 11500000, guid: acb8c4c8a0a4dc6418e2f4d59454f5e3, type: 3}
  m_Name: TimeRecorder
  m_EditorClassIdentifier: 
  stateListeners:
  - stateID: 3
    onStateStartedActions:
    - predefinedActionTemplate:
        actionType: Customized Action
        codeSnippet: 
        variables: []
      customAction: '$.state.isInTrial = true;

        $.state.timer = 0;'
      isConditional: 0
      conditionVariable: 
      conditionValue: 
      _variableKeys: []
      _variableValuesList: []
    duringStateActions: []
    onStateExitedActions:
    - predefinedActionTemplate:
        actionType: Customized Action
        codeSnippet: 
        variables: []
      customAction: "$.state.isInTrial = false;\nSendDataToCollector(\n    \"timer\",
        $.state.timer);"
      isConditional: 0
      conditionVariable: 
      conditionValue: 
      _variableKeys: []
      _variableValuesList: []
    - predefinedActionTemplate:
        actionType: Process and save collected data
        codeSnippet: $.sendSignalCompat('this', 'exp_recordCustomData');
        variables: []
      customAction: 
      isConditional: 0
      conditionVariable: 
      conditionValue: 
      _variableKeys: []
      _variableValuesList: []
  - stateID: 5
    onStateStartedActions:
    - predefinedActionTemplate:
        actionType: Upload collected data
        codeSnippet: $.sendSignalCompat('this', 'exp_uploadCustomData');
        variables: []
      customAction: 
      isConditional: 0
      conditionVariable: 
      conditionValue: 
      _variableKeys: []
      _variableValuesList: []
    duringStateActions: []
    onStateExitedActions: []
  otherImplementation: "function Start() { $.state.timer = 0; }\nfunction Update(deltaTime)
    {\n  if ($.state.isInTrial) $.state.timer += deltaTime;\n}"
