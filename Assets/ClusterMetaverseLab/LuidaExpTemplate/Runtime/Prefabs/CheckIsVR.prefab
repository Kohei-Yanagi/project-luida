--- !u!114 &5958870284410104554
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 5958870284410104551}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e61061896c654489a41575fc291bf4a0, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  sourceCodeAsset: {fileID: 0}
  sourceCode: "$.onUpdate(() => {\n  if ($.getStateCompat(\"this\", \"playerJoined\",
    \"boolean\")) {\n    let player = $.getPlayersNear($.getPosition(), Infinity)[0];\n   
    $.setPlayerScript(player);\n    player.send(\"exp_checkIsVr\", true);\n    $.state.player
    = player;\n    $.setStateCompat(\"this\", \"playerJoined\", false)\n  }\n})"
--- !u!114 &5958870284410104553
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 5958870284410104551}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: acb59730322447a7a13c40b87493e196, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  sourceCodeAsset: {fileID: 0}
  sourceCode: "_.onReceive((messageType, arg, sender) => {\n  if (messageType ===
    \"exp_checkIsVr\" && !_.isVr) {\n    if (_.isVr) {\n      _.setMoveSpeedRate(1);\n   
    } else {\n      _.setMoveSpeedRate(0);\n      _.playerLocalObject(\"gate-to-luida-bar\").setEnabled(true);\n   
    }\n  }\n});"
